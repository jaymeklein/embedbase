# ─── Required ─────────────────────────────────────────────────────────────────
# The ONLY application secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MASTER_API_KEY=

# ─── Deploy / bootstrap ───────────────────────────────────────────────────────
# Everything else that used to live here — embedding provider/model, vector store
# backend + connection, parsers/GPU, search, MCP, file-size limit — is now
# application config, owned by config.yaml and editable in the Settings → Config
# page (live reload). Only deployment/bootstrap values that must exist before the
# app can start remain below.

# Infrastructure (Celery broker + SQLite path) — needed before the app boots.
REDIS_URL=redis://redis:6379/0
DATABASE_PATH=/store/embedbase.db

# Middleware / process — applied at API/worker startup.
LOG_LEVEL=info                             # debug | info | warning | error
LOG_FORMAT=json                            # json | text
CELERY_CONCURRENCY=2
CORS_ORIGINS=http://localhost:3000
EMBEDBASE_SECURE_HEADERS=false             # set true for shared-network deployments

# Your machine's LAN IP (private address, e.g. 192.168.x.x) that other devices
# use to reach the MCP server. The bridge-networked container can't detect the
# host's LAN IP, so the start scripts (scripts/up.ps1 / scripts/up.sh) detect it
# on the host and inject it. Set it here to pin a fixed value for plain
# `docker compose up`.
# LAN_HOST=192.168.3.33

# ─── Host-exposed ports (docker-compose only — not read by the app) ───────────
# Map host ports → container ports in docker-compose.yml. Change if the defaults
# conflict. Run `python scripts/check_ports.py` to detect conflicts.
API_PORT=8000                              # host port → API container (internal 8000)
UI_PORT=3000                               # host port → nginx/UI container (internal 80)

# ─── Vector-store deploy overrides (optional) ─────────────────────────────────
# The pgvector/qdrant compose overrides (docker-compose.postgres.yml /
# docker-compose.qdrant.yml) still set these so the DB container and the app
# agree on credentials/topology at boot. They override config.yaml when present.
# Leave unset for the default Chroma stack — configure the vector store in the UI.
# POSTGRES_PASSWORD=
