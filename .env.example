# ─── Required ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MASTER_API_KEY=

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=sentence_transformers   # sentence_transformers | ollama | openai_compat
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Vector store ─────────────────────────────────────────────────────────────
VECTOR_STORE=chroma                        # chroma | pgvector | qdrant

# ─── Chroma (default — no extra config needed) ────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_AUTH_TOKEN=embedbase-internal       # internal auth token — change for shared networks

# ─── pgvector (only needed with docker-compose.postgres.yml) ──────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=embedbase
POSTGRES_USER=embedbase
POSTGRES_PASSWORD=

# ─── Qdrant (only needed with docker-compose.qdrant.yml) ─────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ─── Ollama (only needed when EMBEDDING_PROVIDER=ollama) ─────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CONCURRENCY=8

# ─── OpenAI-compatible (only needed when EMBEDDING_PROVIDER=openai_compat) ───
OPENAI_COMPAT_BASE_URL=http://host.docker.internal:1234
OPENAI_COMPAT_API_KEY=

# ─── Parsers / docling (only needed for the docling heavy path) ──────────────
# Pin a local docling models directory — offline / air-gapped use, or a mounted
# pre-downloaded models volume. Leave blank to use docling's default HF cache.
DOCLING_ARTIFACTS_PATH=

# ─── Infrastructure ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
DATABASE_PATH=/store/embedbase.db

# ─── Application ──────────────────────────────────────────────────────────────
LOG_LEVEL=info                             # debug | info | warning | error
LOG_FORMAT=json                            # json | text
MAX_FILE_SIZE_MB=50
CELERY_CONCURRENCY=2
CORS_ORIGINS=http://localhost:3000
EMBEDBASE_SECURE_HEADERS=false             # set true for shared-network deployments

# ─── Host-exposed ports ───────────────────────────────────────────────────────
# These map host ports → container ports in docker-compose.yml.
# Change them if the defaults conflict with something already running on your machine.
# Run `python scripts/check_ports.py` to detect conflicts before starting the stack.
API_PORT=8000                              # host port → API container (internal 8000)
UI_PORT=3000                              # host port → nginx/UI container (internal 80)
